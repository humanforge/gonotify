# Environment: local, development, staging, production
ENV=local

# Server
PORT=:8080

# Database
DATABASE_CONN_URL=postgres://postgres:postgres@localhost:5432/notification_service?sslmode=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# Logging
LOG_ROOT_PATH=./logs
LOG_LEVEL=info
LOG_MAX_SIZE_MB=100
LOG_MAX_AGE_DAYS=30
LOG_MAX_BACKUPS=5

# Shutdown
SHUTDOWN_TIMEOUT=15s

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=*
